# Copia este archivo a .env y rellena tus valores. .env NO se versiona.
#
#   cp .env.example .env
#
# Lo que ya esté definido en el entorno tiene prioridad sobre el .env.

# --- WordPress (wordpress_sync.py) ---
WP_SITE_URL=https://tu-sitio.example
WP_USERNAME=tu_usuario
WP_APP_PASSWORD=tu_application_password

# --- Ollama, para la mejora de estilo con --enhance ---
# Servidor remoto: descarga el trabajo de tu máquina. Si se deja vacío, solo se
# usa el local. Si está definido y no responde, el script pregunta si tirar del
# local antes de publicar sin reescribir.
OLLAMA_REMOTE=
OLLAMA_LOCAL=http://localhost:11434

# Modelo a usar. Debe existir en el servidor elegido.
OLLAMA_MODEL=

# Fuerza un host concreto e ignora la lógica remoto/local de arriba.
# OLLAMA_HOST=

# Solo para Ollama Cloud (https://ollama.com).
# OLLAMA_API_KEY=
