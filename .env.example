# Variables de entorno para wordpress_sync.py
WP_SITE_URL=https://frikiteam.es
WP_USERNAME=tu_usuario
WP_APP_PASSWORD=tu_app_password

# Mejora "blog" con Ollama (solo si usas --enhance)
# Local:  deja OLLAMA_HOST por defecto y pon un modelo que tengas (ollama pull ...)
# Cloud:  OLLAMA_HOST=https://ollama.com  +  OLLAMA_API_KEY=...
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1
# OLLAMA_API_KEY=tu_api_key_de_ollama_cloud